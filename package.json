{
  "name": "kodo",
  "publisher": "StanislavMorozov",
  "displayName": "Kōdo",
  "icon": "images/kodo128px.png",
  "description": "Agentic build system: requirements → working code.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:kodoPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kodo",
          "title": "Kōdo",
          "icon": "images/kodo24px.svg"
        }
      ]
    },
    "views": {
      "kodo": [
        {
          "id": "kodo.view",
          "name": "Kōdo",
          "type": "webview",
          "icon": "images/kodo16px.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "kodo.openPanel",
        "title": "Kōdo: Open Panel",
        "icon": "images/kodo16px.svg"
      },
      {
        "command": "kodo.openSettings",
        "title": "Kōdo: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "kodo.newSession",
        "title": "Kōdo: Start New Session",
        "icon": "images/kodo16px.svg"
      },
      {
        "command": "kodo.createProject",
        "title": "Kōdo: Create New Project",
        "icon": "images/kodo16px.svg"
      },
      {
        "command": "kodo.useCloudLLMs",
        "title": "Kōdo: Use Cloud LLMs",
        "icon": "images/kodo16px.svg"
      },
      {
        "command": "kodo.useLocalLLM",
        "title": "Kōdo: Use Local LLM via llama.cpp",
        "icon": "images/kodo16px.svg"
      },
      {
        "command": "kodo.pickSession",
        "title": "Kōdo: Open Session…",
        "icon": "images/kodo16px.svg"
      },
      {
        "command": "kodo.addFeedback",
        "title": "Kōdo: Add Feedback"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "kodo.openSettings",
          "when": "view == kodo.view",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "kodo.newSession",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "kodo.addFeedback",
          "when": "resourceScheme == kodo-review && editorHasSelection",
          "group": "kodo"
        }
      ]
    }
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.14",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "preact": "^10.26.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
